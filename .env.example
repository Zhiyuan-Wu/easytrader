# EasyTrader 远程交易服务配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ── 服务配置 ──

# 监听端口，默认 1430
PORT=1430

# API Key 认证密钥（强烈建议设置，否则服务无认证保护）
EASYTRADER_API_KEY=

# ── 服务端默认参数（客户端调用 /prepare 时可覆盖）──

# 券商客户端可执行文件路径（服务端本地路径）
# 例如: C:\银河证券\xiadan.exe
EXE_PATH=

# 通讯密码（华泰、海通等需要）
COMM_PASSWORD=

# ── 凭证加密 ──

# 配置文件中加密字段的主密码（使用 easytrader encrypt 加密后需要设置）
EASYTRADER_MASTER_PASSWORD=
