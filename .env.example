# EasyTrader 远程交易服务配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ── 服务配置 ──

# 监听端口，默认 1430
PORT=1430

# API Key 认证密钥（强烈建议设置，否则服务无认证保护）
EASYTRADER_API_KEY=

# ── 券商登录配置 ──

# 券商类型，支持: yh_client | ht_client | htzq_client | gj_client | gf_client |
#   wk_client | universal_client | ths | miniqmt | xq
BROKER=yh_client

# 登录方式一：配置文件路径（与下方账号密码二选一）
# 配置文件为 JSON 格式，如 {"user": "账号", "password": "密码", "exe_path": "路径"}
CONFIG_PATH=

# 登录方式二：直接填写账号密码
USER=
PASSWORD=

# 客户端可执行文件路径（部分券商需要）
EXE_PATH=

# 通讯密码（华泰、海通等需要）
COMM_PASSWORD=

# ── 凭证加密 ──

# 配置文件中加密字段的主密码（使用 easytrader encrypt 加密后需要设置）
EASYTRADER_MASTER_PASSWORD=
